# RubricMaker — Docker environment configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# ── OPTION A: Single machine or school LAN (HTTP) ────────────────────────────
#   1. cp .env.docker.example .env
#   2. Set SITE_URL to your machine's IP if other teachers need access
#   3. docker-compose up -d --build
#   4. Open SITE_URL in a browser
#
# ── OPTION B: VPS / public server (HTTPS + domain) ───────────────────────────
#   1. cp .env.docker.example .env
#   2. Fill in DOMAIN and set SITE_URL to https://<your-domain>
#   3. Change JWT_SECRET and POSTGRES_PASSWORD to random values
#   4. docker-compose --profile https up -d --build
#   Caddy will automatically obtain a free Let's Encrypt certificate.
#   Firewall: open ports 80 and 443.


# ── URLs ──────────────────────────────────────────────────────────────────────

# Where teachers open RubricMaker. Examples:
#   http://localhost:8080          ← your own laptop
#   http://192.168.1.10:8080       ← school server on LAN
#   https://rubricmaker.school.nl  ← VPS with HTTPS (set DOMAIN below too)
SITE_URL=http://localhost:8080

# Domain for HTTPS (only needed with --profile https).
# Must match the A-record pointing to your VPS.
# Leave empty for HTTP-only deployments.
DOMAIN=


# ── Security ──────────────────────────────────────────────────────────────────
# Change both of these for any internet-facing server.

# Postgres admin password
POSTGRES_PASSWORD=postgres

# JWT signing secret (all login tokens are signed with this).
# Generate a new one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long


# ── API keys ──────────────────────────────────────────────────────────────────
# These are JWTs signed with JWT_SECRET above.
# The defaults match the default JWT_SECRET — only change them if you changed
# JWT_SECRET (regenerate at https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys).
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU


# ── Email login (optional) ────────────────────────────────────────────────────
# Without SMTP: anonymous login works, but teachers can't link an email address
#               (rubric sharing across devices won't work).
# With SMTP: teachers can add their email and log in with an 8-digit OTP code.
#
# To enable:
#   1. Set MAILER_AUTOCONFIRM=false
#   2. Fill in your SMTP server details
#   3. Restart:  docker-compose up -d --force-recreate auth
#
# Common SMTP options:
#   Office 365:  smtp.office365.com  port 587
#   Gmail:       smtp.gmail.com      port 587  (needs an App Password)
#   Brevo:       smtp-relay.brevo.com port 587  (free tier: 300 emails/day)
MAILER_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=rubricmaker@school.nl
