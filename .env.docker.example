# RubricMaker — Docker environment configuration
# ─────────────────────────────────────────────
# 1. Copy this file:   cp .env.docker.example .env
# 2. Edit as needed    (see comments below)
# 3. Start everything: docker-compose up -d
# 4. Open your browser at SITE_URL
#
# Single machine (laptop/desktop): leave everything at the defaults.
# School server:  change SITE_URL to http://<server-ip>:8080

# ── App URL ────────────────────────────────────────────────────────────────────
# Where teachers open RubricMaker in their browser.
SITE_URL=http://localhost:8080

# ── Database password ──────────────────────────────────────────────────────────
# Password for the postgres admin user.
# Change this on any internet-facing server.
POSTGRES_PASSWORD=postgres

# ── JWT secret ─────────────────────────────────────────────────────────────────
# Used to sign and verify login tokens.
# Change this on any internet-facing server.
# Generate a new one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ── API keys ───────────────────────────────────────────────────────────────────
# These are JWT tokens signed with JWT_SECRET above.
# The defaults below match the default JWT_SECRET — only change them if you
# change JWT_SECRET (use https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# to regenerate them).
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── Email login (optional) ─────────────────────────────────────────────────────
# Without SMTP: anonymous login works, but teachers cannot link an email address
#               (so sharing rubrics across devices is not possible).
# With SMTP:    teachers can add an email address and use OTP login codes.
#
# To enable email login:
#   1. Set MAILER_AUTOCONFIRM=false
#   2. Fill in SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
#   3. Run:  docker-compose up -d --force-recreate auth
#
MAILER_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=rubricmaker@school.nl
