# RubricMaker — observability stack environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# cp .env.observability.example .env.observability
# docker-compose -f docker-compose.observability.yml --env-file .env.observability up -d
# Open http://localhost:3001


# ── Grafana ────────────────────────────────────────────────────────────────────
# Change this for any internet-facing server.
GRAFANA_ADMIN_PASSWORD=admin

# Set these when Grafana is reverse-proxied on its own (sub)domain, e.g. via
# HestiaCP — see docs/OBSERVABILITY_HESTIACP.md. Leave both blank for
# localhost-only access (http://localhost:3001).
#   GRAFANA_DOMAIN=observability.rubricmaker.example.com
#   GRAFANA_ROOT_URL=https://observability.rubricmaker.example.com/
GRAFANA_DOMAIN=
GRAFANA_ROOT_URL=


# ── Web server logs (Promtail) ───────────────────────────────────────────────────
# Directory Promtail scans (recursively) for *access*.log / *error*.log files.
# Examples:
#   /var/log                              ← default; covers /var/log/virtualmin,
#                                            /var/log/nginx, /var/log/apache2, etc.
#   /home/rubricmaker/web/*/log           ← HestiaCP per-domain logs
#   /var/log/virtualmin                   ← Virtualmin vhost logs
# Combined docker-compose.yml stack: leave as default — Promtail's Docker scrape
# job picks up the `app` container's stdout logs directly (see nginx.prod.conf).
RUBRICMAKER_LOG_DIR=/var/log


# ── client_logs (Part 1 app-level diagnostics) ───────────────────────────────────
# Optional: lets Grafana query the `client_logs` table (see README → "Stress-test
# logging") directly via a Postgres datasource. Leave all four blank to skip —
# Loki (web server / container logs) still works without these.
#
# Self-hosted db (combined docker-compose.yml on this host): set
#   SUPABASE_DB_HOST=db
# and uncomment the `networks:` block in docker-compose.observability.yml.
#
# Managed Supabase project: find these in
#   Project Settings → Database → Connection parameters
SUPABASE_DB_HOST=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=


# ── Managed Supabase (no self-hosted Postgres/containers to scrape) ──────────────
# If RubricMaker uses Supabase Cloud (not self-hosted), there are no local
# container/file logs for the Supabase services themselves — use the Supabase
# dashboard's Log Explorer for those. This stack still covers your web server
# logs (RUBRICMAKER_LOG_DIR) and the cross-deployment client_logs table
# (SUPABASE_DB_* above).
