# RubricMaker environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase (optional) ───────────────────────────────────────────────────────
# For local development: run `supabase start` and use the printed values.
# For cloud: create a project at supabase.com and use your project's URL and anon key.
#
# If these are set, they pre-fill the DB connection form in Settings > Database.
# Teachers can still override them with their own values in the UI.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
