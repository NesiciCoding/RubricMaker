# RubricMaker — production environment variables
# Copy to .env and fill in values on the server.
# Never commit the filled-in .env to version control.

# ── Supabase connection (pre-fills the DB Settings form) ─────────────────────
# Replace with the IP/hostname where Supabase is running on your school server.
# If the app and Supabase run on the same machine, use 127.0.0.1.
VITE_SUPABASE_URL=http://192.168.1.10:54321
VITE_SUPABASE_ANON_KEY=<paste anon key printed by `supabase status`>

# ── SMTP password (referenced in supabase/config.toml as env(SMTP_PASSWORD)) ─
# Set this on the server before running `supabase start`.
SMTP_PASSWORD=<your smtp password>
